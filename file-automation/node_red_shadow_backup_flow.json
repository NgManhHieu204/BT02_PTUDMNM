    {
        "id": "25af1e37e2dc7d09",
        "type": "function",
        "z": "53e37fead0051f0d",
        "name": "Lệnh Backup",
        "func": "// Lấy đường dẫn file gốc\nvar filePath = msg.payload;\n\n// Tách lấy tên file\nvar fileName = filePath.split('/').pop();\n\n// Tạo lệnh copy của Linux\nmsg.payload = \"cp '\" + filePath + \"' '/backup/\" + fileName + \"'\";\n\nreturn msg;",
