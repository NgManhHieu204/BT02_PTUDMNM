        "z": "53e37fead0051f0d",
        "name": "Tạo tin nhắn Upload",
        "func": "// Lấy đường dẫn file\nvar filePath = msg.payload; \n\n// Tách lấy tên file\nvar fileName = filePath.split('/').pop(); \n\nmsg.payload = {\n    chatId: \"YOUR_CHAT_ID_HERE\", \n    type: \"message\",\n    content: \"🟢 [HỆ THỐNG HOMELAB]\\nBạn ơi, Phát hiện tệp tin \" + fileName +  \" mới được bổ sung vào phân vùng lưu trữ chung. \"\n};\n\nreturn msg;",
