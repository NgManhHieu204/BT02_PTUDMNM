    {
        "id": "93a677208aca5287",
        "type": "function",
        "z": "53e37fead0051f0d",
        "name": "Xử lý Versioning & Backup",
        "func": "// Lấy thông tin file đầu vào\nvar filePath = msg.payload;\nvar fullFileName = filePath.split('/').pop();\n\n// Bóc tách tên gốc và phần mở rộng\nvar extIndex = fullFileName.lastIndexOf('.');\nvar baseName = extIndex !== -1 ? fullFileName.substring(0, extIndex) : fullFileName;\nvar ext = extIndex !== -1 ? fullFileName.substring(extIndex) : '';\n\n// Khởi tạo chuỗi định dạng Timestamp: YYYYMMDD_HHMMSS\nvar d = new Date();\nvar timestamp = d.getFullYear() + \n                (\"0\" + (d.getMonth() + 1)).slice(-2) + \n                (\"0\" + d.getDate()).slice(-2) + \"_\" + \n                (\"0\" + d.getHours()).slice(-2) + \n                (\"0\" + d.getMinutes()).slice(-2) + \n                (\"0\" + d.getSeconds()).slice(-2);\n\n// Định dạng tên tệp mới\nvar newFileName = baseName + \"_modified_\" + timestamp + ext;\n\n// Khởi tạo lệnh sao lưu\nmsg.payload = \"cp '\" + filePath + \"' '/backup/\" + newFileName + \"'\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 320,
        "wires": [
